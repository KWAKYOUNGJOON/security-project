      "properties": {
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "finding_id",
              "type",
              "label",
              "path",
              "caption",
              "sha256"
            ],
            "properties": {
              "finding_id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "caption": {
                "type": "string"
              },
              "sha256": {
                "type": "string"
              }
            }
          }
        },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "finding_id",
              "taxonomy",
              "code",
              "title_ko",
              "severity",
              "canonical_key",
              "status"
            ],
            "properties": {
              "finding_id": {
                "type": "string"
              },
              "taxonomy": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name",
                  "version"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  }
                }
              },
              "code": {
                "type": "string"
              },
              "title_ko": {
                "type": "string"
              },
              "severity": {
                "type": "string"
              },
              "canonical_key": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            }
          }
        }
      }
