      ],
      "properties": {
        "short_term": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mid_term": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "long_term": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "appendix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "checklist"
