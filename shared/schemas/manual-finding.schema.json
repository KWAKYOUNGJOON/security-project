{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manual Finding Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "taxonomy",
    "code",
    "title_ko",
    "severity",
    "summary",
    "description",
    "impact",
    "affected",
    "reproduction",
    "remediation"
  ],
  "properties": {
    "finding_id": {
      "type": "string"
    },
    "taxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "code": {
      "type": "string"
    },
    "title_ko": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "target_ref": {
      "type": "string"
    },
    "finding_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "cause": {
      "type": "string"
    },
    "impact": {
      "type": "string"
    },
    "affected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "parameter": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "reproduction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rationale": {
          "type": "string"
        },
        "difficulty": {
          "type": "string"
        },
        "asset": {
          "type": "string"
        },
        "precondition": {
          "type": "string"
        }
      }
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "short_term"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "short_term": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "mid_term": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "long_term": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_basis": {
      "type": "string"
    },
    "exception_note": {
      "type": "string"
    },
    "false_positive": {
      "type": "boolean"
    },
    "status": {
      "type": "string"
    },
    "owner": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviewer": {
      "type": [
        "string",
        "null"
      ]
    },
    "due_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": "string"
    },
    "screenshot_captions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
