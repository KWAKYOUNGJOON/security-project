{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reviewed Web Findings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "platform",
    "case_id",
    "source_artifact",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "platform": {
      "type": "string",
      "const": "web"
    },
    "case_id": {
      "type": "string"
    },
    "source_artifact": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "review_key",
          "finding_id",
          "platform",
          "title",
          "target",
          "source",
          "classification",
          "summary",
          "description",
          "impact",
          "remediation",
          "evidence",
          "review"
        ],
        "properties": {
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "included_in_report",
              "overridden_fields",
              "resolution",
              "suppression",
              "exception",
              "review_history"
            ],
            "properties": {
              "included_in_report": {
                "type": "boolean"
              },
              "overridden_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "resolution": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "required": [
                  "resolution",
                  "final_status",
                  "reason",
                  "reviewer",
                  "reviewed_at"
                ],
                "properties": {
                  "resolution": {
                    "type": "string"
                  },
                  "final_status": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  },
                  "reviewer": {
                    "type": "string"
                  },
                  "reviewed_at": {
                    "type": "string"
                  }
                }
              },
              "suppression": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "required": [
                  "action",
                  "reason_code",
                  "reason",
                  "reviewer",
                  "reviewed_at"
                ],
                "properties": {
                  "action": {
                    "type": "string"
                  },
                  "reason_code": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  },
                  "reviewer": {
                    "type": "string"
                  },
                  "reviewed_at": {
                    "type": "string"
                  }
                }
              },
              "exception": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "required": [
                  "exception_type",
                  "approved_by",
                  "expires_at",
                  "note"
                ],
                "properties": {
                  "exception_type": {
                    "type": "string"
                  },
                  "approved_by": {
                    "type": "string"
                  },
                  "expires_at": {
                    "type": "string"
                  },
                  "note": {
                    "type": "string"
                  }
                }
              },
              "review_history": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "order",
                    "review_key",
                    "action_type",
                    "changed_fields",
                    "reason",
                    "reviewer",
                    "reviewed_at",
                    "result"
                  ],
                  "properties": {
                    "order": {
                      "type": "integer"
                    },
                    "review_key": {
                      "type": "string"
                    },
                    "action_type": {
                      "type": "string"
                    },
                    "changed_fields": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "reason": {
                      "type": "string"
                    },
                    "reviewer": {
                      "type": "string"
                    },
                    "reviewed_at": {
                      "type": "string"
                    },
                    "result": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
