{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HexStrike Synthetic vs Live Delta",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "comparison_kind",
    "synthetic_run_id",
    "live_run_id",
    "linkage_comparison_succeeded",
    "status_reference",
    "comparison",
    "promotion_impact_summary",
    "conclusion"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "comparison_kind": {
      "type": "string"
    },
    "synthetic_run_id": {
      "type": "string"
    },
    "live_run_id": {
      "type": "string"
    },
    "linkage_comparison_succeeded": {
      "type": "boolean"
    },
    "status_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linkage_status",
        "validation_status",
        "observation_kind",
        "report_ready",
        "promotable_to_cases"
      ],
      "properties": {
        "linkage_status": {
          "type": "string"
        },
        "validation_status": {
          "type": "string"
        },
        "observation_kind": {
          "type": "string"
        },
        "report_ready": {
          "type": "boolean"
        },
        "promotable_to_cases": {
          "type": "boolean"
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "top_level_keys",
        "finding_count_detection",
        "finding_identifier_fields",
        "severity_status_enum",
        "request_response_location",
        "evidence_screenshot_structure",
        "unknown_fields",
        "missing_expected_fields",
        "parser_warnings"
      ],
      "properties": {
        "top_level_keys": {
          "$ref": "#/$defs/syntheticLiveArrays"
        },
        "finding_count_detection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "synthetic_method",
            "synthetic_detected",
            "live_method",
            "live_detected"
          ],
          "properties": {
            "synthetic_method": {
              "type": "string"
            },
            "synthetic_detected": {
              "type": "integer"
            },
            "live_method": {
              "type": "string"
            },
            "live_detected": {
              "type": "integer"
            }
          }
        },
        "finding_identifier_fields": {
          "$ref": "#/$defs/syntheticLiveArrays"
        },
        "severity_status_enum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["synthetic", "live"],
          "properties": {
            "synthetic": {
              "$ref": "#/$defs/enumSummary"
            },
            "live": {
              "$ref": "#/$defs/enumSummary"
            }
          }
        },
        "request_response_location": {
          "$ref": "#/$defs/syntheticLiveArrays"
        },
        "evidence_screenshot_structure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["synthetic", "live"],
          "properties": {
            "synthetic": {
              "$ref": "#/$defs/evidenceSummary"
            },
            "live": {
              "$ref": "#/$defs/evidenceSummary"
            }
          }
        },
        "unknown_fields": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "synthetic_count",
            "synthetic_fields",
            "live_count",
            "live_fields"
          ],
          "properties": {
            "synthetic_count": {
              "type": "integer"
            },
            "synthetic_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "live_count": {
              "type": "integer"
            },
            "live_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "missing_expected_fields": {
          "type": "object",
          "additionalProperties": false,
          "required": ["synthetic_count", "live_count"],
          "properties": {
            "synthetic_count": {
              "type": "integer"
            },
            "live_count": {
              "type": "integer"
            }
          }
        },
        "parser_warnings": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "synthetic_count",
            "synthetic_warnings",
            "live_count",
            "live_warnings"
          ],
          "properties": {
            "synthetic_count": {
              "type": "integer"
            },
            "synthetic_warnings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "live_count": {
              "type": "integer"
            },
            "live_warnings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "promotion_impact_summary": {
      "type": "string"
    },
    "conclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linkage_comparison_succeeded",
        "promotion_decision",
        "promotion_decision_remains_blocked",
        "why_blocked"
      ],
      "properties": {
        "linkage_comparison_succeeded": {
          "type": "boolean"
        },
        "promotion_decision": {
          "type": "string"
        },
        "promotion_decision_remains_blocked": {
          "type": "boolean"
        },
        "why_blocked": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "syntheticLiveArrays": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthetic", "live"],
      "properties": {
        "synthetic": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "live": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "enumSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity_values",
        "status_values",
        "severity_field_shapes",
        "status_field_shapes"
      ],
      "properties": {
        "severity_values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status_values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "severity_field_shapes": {
          "$ref": "#/$defs/countMap"
        },
        "status_field_shapes": {
          "$ref": "#/$defs/countMap"
        }
      }
    },
    "evidenceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "evidence_field_shapes",
        "evidence_item_kinds"
      ],
      "properties": {
        "path": {
          "type": ["string", "null"]
        },
        "evidence_field_shapes": {
          "$ref": "#/$defs/countMap"
        },
        "evidence_item_kinds": {
          "$ref": "#/$defs/countMap"
        }
      }
    },
    "countMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    }
  }
}
