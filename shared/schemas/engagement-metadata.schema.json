{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Engagement Metadata Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "engagement"
  ],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "version",
        "date",
        "classification"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "classification": {
          "type": "string"
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "version",
              "date",
              "author",
              "change_log"
            ],
            "properties": {
              "version": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "author": {
                "type": "string"
              },
              "change_log": {
                "type": "string"
              }
            }
          }
        },
        "approvals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "department",
              "name",
              "status",
              "note"
            ],
            "properties": {
              "kind": {
                "type": "string"
              },
              "department": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "engagement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "customer_name",
        "scope_type",
        "location",
        "targets",
        "schedule",
        "team"
      ],
      "properties": {
        "project_name": {
          "type": "string"
        },
        "customer_name": {
          "type": "string"
        },
        "scope_type": {
          "type": "string",
          "const": "web"
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "address",
            "ip",
            "access_method",
            "note"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "ip": {
              "type": "string"
            },
            "access_method": {
              "type": "string"
            },
            "note": {
              "type": "string"
            }
          }
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "service_name",
              "base_url",
              "account_level",
              "note"
            ],
            "properties": {
              "target_id": {
                "type": "string"
              },
              "service_name": {
                "type": "string"
              },
              "base_url": {
                "type": "string"
              },
              "environment": {
                "type": "string"
              },
              "auth_context": {
                "type": "string"
              },
              "account_level": {
                "type": "string"
              },
              "criticality": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            }
          }
        },
        "schedule": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "phase",
              "date",
              "deliverable",
              "content"
            ],
            "properties": {
              "phase": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "deliverable": {
                "type": "string"
              },
              "content": {
                "type": "string"
              }
            }
          }
        },
        "team": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "company",
              "name",
              "role",
              "scope",
              "contact"
            ],
            "properties": {
              "company": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "scope": {
                "type": "string"
              },
              "contact": {
                "type": "string"
              }
            }
          }
        },
        "purpose": {
          "type": "string"
        },
        "purpose_note": {
          "type": "string"
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "assumptions",
            "assumptions_status",
            "exclusions",
            "exclusions_status",
            "limitations",
            "limitations_status"
          ],
          "properties": {
            "assumptions": {
              "type": "string"
            },
            "assumptions_status": {
              "type": "string"
            },
            "exclusions": {
              "type": "string"
            },
            "exclusions_status": {
              "type": "string"
            },
            "limitations": {
              "type": "string"
            },
            "limitations_status": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
