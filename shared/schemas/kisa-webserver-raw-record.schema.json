{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KISA Webserver Raw Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_kind",
    "source_file",
    "platform",
    "service_name",
    "item_id",
    "item_key",
    "title",
    "severity",
    "raw_status",
    "inspection_summary",
    "hostname",
    "timestamp",
    "check_type",
    "executed_command",
    "command_output",
    "guideline_text",
    "guideline_reference",
    "config_path",
    "registry_path",
    "applicability",
    "parser_confidence",
    "parse_warnings"
  ],
  "properties": {
    "source_kind": {
      "type": "string",
      "enum": ["item_json", "run_all_json"]
    },
    "source_file": {
      "type": "string"
    },
    "platform": {
      "type": ["string", "null"],
      "enum": ["apache", "nginx", "iis", "tomcat", null]
    },
    "service_name": {
      "type": ["string", "null"]
    },
    "item_id": {
      "type": ["string", "null"]
    },
    "item_key": {
      "type": ["string", "null"]
    },
    "title": {
      "type": ["string", "null"]
    },
    "severity": {
      "type": ["string", "null"]
    },
    "raw_status": {
      "type": ["string", "null"]
    },
    "inspection_summary": {
      "type": ["string", "null"]
    },
    "hostname": {
      "type": ["string", "null"]
    },
    "timestamp": {
      "type": ["string", "null"]
    },
    "check_type": {
      "type": "string",
      "enum": ["config", "file", "command", "manual", "version", "heuristic", "unknown"]
    },
    "executed_command": {
      "type": ["string", "null"]
    },
    "command_output": {
      "type": ["string", "null"]
    },
    "guideline_text": {
      "type": ["string", "null"]
    },
    "guideline_reference": {
      "type": ["string", "null"]
    },
    "config_path": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "registry_path": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applicability": {
      "type": ["string", "null"]
    },
    "parser_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "parse_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
