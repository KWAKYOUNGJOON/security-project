{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Audit Log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "generated_at",
    "source_artifact",
    "actions"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "source_artifact": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "review_key",
          "action_type",
          "changed_fields",
          "reason",
          "reviewer",
          "reviewed_at",
          "result"
        ],
        "properties": {
          "order": {
            "type": "integer"
          },
          "review_key": {
            "type": "string"
          },
          "action_type": {
            "type": "string"
          },
          "changed_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "reviewer": {
            "type": "string"
          },
          "reviewed_at": {
            "type": "string"
          },
          "result": {
            "type": "string"
          }
        }
      }
    }
  }
}
